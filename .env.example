AI_GATEWAY_API_KEY=

# Headroom (https://github.com/chopratejas/headroom) compresses tool outputs
# and conversation history before they reach the model, cutting token usage.
# Optional — unset means no compression, same as before. Set ONE of:
#   HEADROOM_BASE_URL to point at a proxy you run locally (`headroom proxy`,
#     installed via `pip install "headroom-ai[all]"` or `uv tool install`)
#   HEADROOM_API_KEY to use Headroom Cloud instead
# Not wired up for production: this app deploys as Vercel serverless
# functions, which can't host the long-running `headroom proxy` process.
HEADROOM_BASE_URL=
HEADROOM_API_KEY=

# RankForge SEO scan — all optional. The on-page scan, keyword intent, and lead
# capture work with none of these set.
# Higher PageSpeed Insights quota (the scan calls PSI without a key by default):
PAGESPEED_API_KEY=
# Enables the live competitor top-10 comparison (https://serpapi.com):
SERPAPI_KEY=
# Fallback fetch for sites behind Cloudflare/WAF bot protection. A scraping/
# render proxy endpoint with a {{url}} placeholder (key included), e.g.:
#   https://api.scraperapi.com/?api_key=KEY&render=true&url={{url}}
#   https://app.scrapingbee.com/api/v1/?api_key=KEY&url={{url}}
SCRAPE_API_TEMPLATE=
# Generic lead webhook — point at Zapier / Make / a Google Apps Script Web App
# (-> Google Sheet) / a CRM intake endpoint. Receives the raw lead JSON:
LEADS_WEBHOOK_URL=
# Slack incoming webhook — posts a formatted "New SEO Audit Lead" message:
SLACK_WEBHOOK_URL=
# Connect Google (Phase H) — one-click OAuth for Search Console + Analytics
# (read-only). Create a Google Cloud OAuth client and register the redirect URI
#   https://<your-app-domain>/api/oauth/google/callback
# Until these are set the "Connect Google" button honestly reports "not
# configured". OAuth tokens are stored per-project, AES-256-GCM encrypted; there
# is no server-wide Google credential beyond the OAuth app id/secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: pin the OAuth callback origin (otherwise derived from the request
# origin, which works for Vercel preview + production):
GOOGLE_OAUTH_REDIRECT_BASE=

# Pilot administration (RC2 P6). Restrict sign-up to a hand-picked cohort:
# comma-separated exact emails and/or @domains. Unset = open sign-up.
RF_SIGNUP_ALLOWLIST=
# Real verification-email delivery (RC2 P4). A POST endpoint receiving
# { to, subject, html, text }. Unset = emails are logged-only (not delivered),
# and honestly reported as such — the operator hands the user the link.
MAIL_WEBHOOK_URL=
# Show the Mission Atlas (external intelligence / Connect Google) tab. Unset =
# hidden (recommended for the pilot, so no Google dead-end). Client-exposed, so
# it must be NEXT_PUBLIC_.
NEXT_PUBLIC_RF_ENABLE_ATLAS=

# WordPress deployment is configured per-project inside the authenticated app
# (Project → WordPress): the site URL + Application Password are stored
# encrypted and scoped to the tenant. There is no server-wide WordPress
# credential env var — the legacy WP_SITE_URL/WP_USER/WP_APP_PASSWORD fallback
# and its unauthenticated /api/wordpress endpoint were removed in D.6 (P5).
