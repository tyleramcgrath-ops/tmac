AI_GATEWAY_API_KEY=

# RankForge SEO scan — all optional. The on-page scan, keyword intent, and lead
# capture work with none of these set.
# Higher PageSpeed Insights quota (the scan calls PSI without a key by default):
PAGESPEED_API_KEY=
# Enables the live competitor top-10 comparison (https://serpapi.com):
SERPAPI_KEY=
# Enables real AI-answer-engine citation tracking (https://perplexity.ai) —
# checks whether your domain is cited when Perplexity's "sonar" model answers
# a tracked query. No other AI engine (ChatGPT, Gemini, Google AI Overviews)
# exposes a public API that returns its grounding sources, so those stay
# honestly "not connected" until one does.
PERPLEXITY_API_KEY=
# Enables real backlink-profile snapshots (total backlinks, referring
# domains, Trust Flow, Citation Flow) via Majestic's Index Item Info API
# (https://majestic.com/support/api-software). A paid third-party index —
# there is no free, comprehensive live source for this data.
MAJESTIC_API_KEY=
# Fallback fetch for sites behind Cloudflare/WAF bot protection. A scraping/
# render proxy endpoint with a {{url}} placeholder (key included), e.g.:
#   https://api.scraperapi.com/?api_key=KEY&render=true&url={{url}}
#   https://app.scrapingbee.com/api/v1/?api_key=KEY&url={{url}}
SCRAPE_API_TEMPLATE=
# Generic lead webhook — point at Zapier / Make / a Google Apps Script Web App
# (-> Google Sheet) / a CRM intake endpoint. Receives the raw lead JSON:
LEADS_WEBHOOK_URL=
# Slack incoming webhook — posts a formatted "New SEO Audit Lead" message:
SLACK_WEBHOOK_URL=
# Connect Google (Phase H) — one-click OAuth for Search Console + Analytics
# (read-only). Create a Google Cloud OAuth client and register the redirect URI
#   https://<your-app-domain>/api/oauth/google/callback
# Until these are set the "Connect Google" button honestly reports "not
# configured". OAuth tokens are stored per-project, AES-256-GCM encrypted; there
# is no server-wide Google credential beyond the OAuth app id/secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: pin the OAuth callback origin (otherwise derived from the request
# origin, which works for Vercel preview + production):
GOOGLE_OAUTH_REDIRECT_BASE=

# Pilot administration (RC2 P6). Restrict sign-up to a hand-picked cohort:
# comma-separated exact emails and/or @domains. Unset = open sign-up.
RF_SIGNUP_ALLOWLIST=
# Pilot admin surface (/admin, /api/admin/*): comma-separated exact emails of
# RankForge staff allowed to view every org and set org.pilot status/expiry.
# Unset = nobody is staff; the admin routes 404 for everyone.
RF_STAFF_EMAILS=
# Real verification/invitation-email delivery (RC2 P4). Two options, tried in
# this order — set at most one, Resend is simpler:
#
# 1) Resend (https://resend.com) — sends directly, no relay to build. Get an
#    API key from https://resend.com/api-keys.
RESEND_API_KEY=
# Sender shown on outbound mail. The default (onboarding@resend.dev) is
# Resend's shared testing domain — it only delivers to the email address on
# your Resend account, not to real users. To email real users, verify your
# own domain in Resend and set this to an address on it, e.g.
#   RankForge <noreply@yourdomain.com>
RESEND_FROM_EMAIL=
#
# 2) Generic webhook — any other provider. A POST endpoint receiving
#    { to, subject, html, text }.
MAIL_WEBHOOK_URL=
#
# If neither is set, emails are logged-only (not delivered), and honestly
# reported as such — the operator hands the user the link.
# Show the Mission Atlas (external intelligence / Connect Google) tab. Unset =
# hidden (recommended for the pilot, so no Google dead-end). Client-exposed, so
# it must be NEXT_PUBLIC_.
NEXT_PUBLIC_RF_ENABLE_ATLAS=

# Billing (Stripe). Gates ONE thing: whether an org may auto-deploy fixes to a
# live WordPress site (Operator, WordPress tab, Internal Links auto-link).
# Audits, recommendations, and rollback are never gated. Unset = billing is
# not configured on this deployment and automation is unrestricted for
# everyone — matches every other optional integration above.
# Secret key from https://dashboard.stripe.com/apikeys:
STRIPE_SECRET_KEY=
# Signing secret for a webhook endpoint you create pointing at
#   https://<your-app-domain>/api/billing/webhook
# subscribed to: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted.
STRIPE_WEBHOOK_SECRET=
# Monthly price in cents. Default 4900 = $49.00/month. No Stripe Product/Price
# needs to pre-exist — Checkout is created with ad-hoc price_data.
STRIPE_PRICE_CENTS=4900
# Plan name shown in the billing UI and on the Checkout page.
STRIPE_PRICE_LABEL=RankForge Pro

# WordPress deployment is configured per-project inside the authenticated app
# (Project → WordPress): the site URL + Application Password are stored
# encrypted and scoped to the tenant. There is no server-wide WordPress
# credential env var — the legacy WP_SITE_URL/WP_USER/WP_APP_PASSWORD fallback
# and its unauthenticated /api/wordpress endpoint were removed in D.6 (P5).
