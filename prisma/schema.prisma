  expectedOutcome String? // What success looks like
  targetWordCount Int?

  // User review status
  status      String    @default("draft") // draft, approved, generating, generated, deployed
  approvedBy  String?
  approvedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generatedContent GeneratedContent?

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([businessObjective])
}

model GeneratedContent {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  briefId        String  @unique
  pageUrl        String? // NULL for new pages

  contentType String // blog_article, service_page, location_page, faq_section, comparison_page, landing_page, cluster_page

  // Generated content
  generatedTitle           String
  generatedMetaDescription String
  generatedBody            String // Full HTML or markdown
  generatedHeadings        String[] @default([]) // H1, H2, H3 structure
  generatedSchema          String? // JSON-LD

  // Internal linking
  generatedInternalLinks String[] @default([]) // JSON: [{url, anchor}]

  // Scores
  seoOptimizationScore   Float @default(0)
  businessAlignmentScore Float @default(0)
  readabilityScore       Float @default(0)
  keyword1Relevance      Float @default(0)
  keyword2Relevance      Float @default(0)

  // Approval workflow
  approvalStatus String    @default("pending") // pending, approved, rejected, deployed
  approvalNotes  String?
  approvedBy     String?
  approvedAt     DateTime?

  // Deployment
  deployedAt       DateTime?
  deploymentStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brief        ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([approvalStatus])
  @@index([deployedAt])
}

model ContentDiff {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String

  // Current state
  currentTitle           String?
  currentMetaDescription String?
  currentHeadings        String[] @default([])
  currentWordCount       Int      @default(0)
  currentSchema          String?

  // Suggested changes
  suggestedTitle           String?
  suggestedMetaDescription String?
  suggestedHeadings        String[] @default([])
  suggestedWordCount       Int?
  suggestedSchema          String?

  // Impact analysis
  estimatedSeoImpact        String // "high_positive", "moderate_positive", "low_positive", "neutral", "negative"
  seoImpactExplanation      String?
  estimatedBusinessImpact   String
  businessImpactExplanation String?

  // Change tracking
  changesHighlighted String[] // JSON: [{section, current, suggested, impact}]
  diffSummary        String?

  // Approval
  isApproved Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([estimatedSeoImpact])
}

model InternalLinkRecommendation {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  fromPageUrl    String
  toPageUrl      String

  // Link details
  suggestedAnchorText String
  linkContext         String? // Surrounding text for context
  priority            String  @default("medium") // high, medium, low

  // Why this link helps
  rationale        String
  estimatedBenefit String? // "improves_topical_relevance", "builds_authority", "supports_conversion_goal", etc

  // Relationship
  isTopicallyRelevant  Boolean @default(true)
  isAuthorityBuilder   Boolean @default(false)
  isConversionRelevant Boolean @default(false)

  // Status
  isImplemented Boolean   @default(false)
  implementedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromPageUrl, toPageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([priority])
  @@index([isImplemented])
}

model ContentDecayAlert {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String

  // What's declining
  decayType       String // traffic_loss, ranking_loss, ctr_decline, impressions_decline
  severity        String @default("medium") // high, medium, low
  decayPercentage Float

  // Timeline
  detectedAt     DateTime  @default(now())
  decayStartedAt DateTime?
  lastMeasuredAt DateTime?
  trend30d       Float?

  // Context
  currentValue   Float
  previousValue  Float
  potentialCause String[]

  // Resolution
  isResolved Boolean   @default(false)
  resolvedBy String? // Content refresh, new internal links, etc
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([severity])
  @@index([decayType])
  @@index([isResolved])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 7.8F: CONTENT INTELLIGENCE PIPELINE
// ─────────────────────────────────────────────────────────────────────────────

model PipelineRun {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  auditId        String? // Reference to source crawl audit

  // Run metadata
  status String  @default("queued") // queued, running, completed, partial, failed, blocked, cancelled
  reason String? // For failures/blocks

  // Execution timeline
  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // milliseconds

  // Results summary
  pagesQueued    Int @default(0)
  pagesProcessed Int @default(0)
  pagesSkipped   Int @default(0)
  pagesFailed    Int @default(0)

  // Stage tracking
  stages PipelineStage[]

  // Evidence for Forge
  forgeContext String? // JSON containing grounding evidence

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model PipelineStage {
  id    String @id @default(cuid())
  runId String

  // Stage info
  stageName String // "content_inventory", "classification", "topic_detection", etc
  status    String @default("pending") // pending, running, completed, partial, failed, blocked

  // Execution
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // milliseconds

  // Results
  itemsProcessed Int @default(0)
  itemsFailed    Int @default(0)
  itemsSkipped   Int @default(0)

  // Error handling
  error       String?
  failedItems String? // JSON array of failed page URLs

  // Evidence
  evidence String? // JSON containing stage-specific results

  run PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stageName])
  @@index([runId])
  @@index([status])
}

model ContentEntity {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String

  // Entity details
  entityName String
  entityType String // person, organization, place, product, service, topic, etc
  confidence Float // 0-1

  // Detection source
  detectionSource String[] // "heading", "schema", "cooccurrence", "cross_reference", "manual_override"

  // Evidence
  mentions Int      @default(1)
  contexts String[] // JSON: surrounding text snippets

  // Relationships
  relatedEntities String[] @default([]) // JSON: entity IDs

  // Manual override
  isVerified Boolean   @default(false)
  verifiedBy String?
  verifiedAt DateTime?

  // Hash for change detection
  contentHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl, entityName])
  @@index([organizationId])
  @@index([projectId])
  @@index([entityType])
  @@index([confidence])
}

model ContentTopic {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String

  // Topic details
  topicName    String
  topicCluster String? // Grouping for related topics
  confidence   Float // 0-1

  // Detection signals
  detectionSignals String[] // "heading", "entity_cooccurrence", "semantic_similarity", "industry_map", "manual"

  // Relationships
  parentTopics  String[] @default([])
  childTopics   String[] @default([])
  relatedTopics String[] @default([])

  // Evidence
  evidenceScore Float @default(0)

  // Manual override
  isConfirmed Boolean   @default(false)
  confirmedBy String?
  confirmedAt DateTime?

  // Hash for change detection
  contentHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl, topicName])
  @@index([organizationId])
  @@index([projectId])
  @@index([confidence])
}

model KnowledgeGraphNode {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  // Node identity
  nodeId    String // Stable, deterministic id derived from label+type
  nodeType  String // page | topic | entity | service | product | location | category | faq | author | schema_type | money_page | business_objective | internal_link
  nodeLabel String
  nodeUrl   String? // For page-typed nodes: canonical URL

  // Node data
  properties String? // JSON blob: confidence, scores, metadata specific to the node type
  pageUrls   String[] @default([]) // Pages where this appears
  frequency  Int      @default(1) // How many pages mention this
  score      Float    @default(0) // Composite importance score

  // Metadata
  isCore     Boolean @default(false) // Is this a core business element?
  coreReason String?
  version    Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outgoing     KnowledgeGraphEdge[] @relation("outgoing")
  incoming     KnowledgeGraphEdge[] @relation("incoming")

  @@unique([projectId, nodeId])
  @@index([organizationId])
  @@index([projectId])
  @@index([nodeType])
  @@index([isCore])
  @@index([projectId, nodeType])
  @@index([projectId, nodeUrl])
}

model KnowledgeGraphEdge {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  fromNodeId String
  toNodeId   String

  // Relationship
  relationshipType String // PAGE_HAS_TOPIC | PAGE_MENTIONS_ENTITY | PAGE_SUPPORTS_PAGE | PAGE_SUPPORTS_MONEY_PAGE | PAGE_LINKS_TO_PAGE | PAGE_TARGETS_LOCATION | PAGE_OFFERS_SERVICE | PAGE_DESCRIBES_PRODUCT | PAGE_CONTAINS_SCHEMA | ENTITY_RELATES_TO_ENTITY | TOPIC_RELATES_TO_TOPIC | SERVICE_RELATES_TO_LOCATION | CATEGORY_CONTAINS_PRODUCT | AUTHOR_WROTE_PAGE | PAGE_HAS_FAQ | PAGE_TARGETS_OBJECTIVE
  confidence       Float  @default(0.8) // 0-1
  strength         Int    @default(1) // Repeated observations reinforce strength

  // Evidence + provenance
  evidence   String? // JSON snippet describing why the edge exists (heading, anchor, schema, cooccurrence…)
  source     String   @default("pipeline") // pipeline | manual | inference | schema
  sources    String[] @default([]) // Optional additional evidence pointers (page URLs, snippets)
  version    Int      @default(1)
  detectedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromNode     KnowledgeGraphNode @relation("outgoing", fields: [projectId, fromNodeId], references: [projectId, nodeId], onDelete: Cascade)
  toNode       KnowledgeGraphNode @relation("incoming", fields: [projectId, toNodeId], references: [projectId, nodeId], onDelete: Cascade)

  @@unique([projectId, fromNodeId, toNodeId, relationshipType])
  @@index([organizationId])
  @@index([projectId])
  @@index([relationshipType])
  @@index([projectId, relationshipType])
  @@index([projectId, fromNodeId])
  @@index([projectId, toNodeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 8.1: OPERATOR MODE (AI SEO EMPLOYEE)
// ─────────────────────────────────────────────────────────────────────────────

/// Persistent work memory for the AI Operator. One row per decision the
/// Operator (or the user acting on the Operator's advice) has taken on a
/// specific page + recommendation type, so we never re-recommend the same
/// action and we can learn from what the user accepted or rejected.
model OperatorMemory {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  // Target
  pageUrl            String
  recommendationType String // money_page_reinforcement, add_faq_schema, refresh_content, etc.

  // Decision
  status    String    @default("proposed") // proposed | accepted | rejected | ignored | deferred | completed | expired | blocked
  reason    String? // Human/user reason when explicit
  decidedAt DateTime?
  decidedBy String? // userId or "operator"
  expiresAt DateTime?

  // Snapshot at decision time — used both for explainability and learning.
  snapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outcomes     OperatorOutcome[]

  @@unique([projectId, pageUrl, recommendationType])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([projectId, status])
  @@index([expiresAt])
}

/// Measured outcome for a memory row — recorded after the user (or an
/// automated deploy) implements a recommendation, so future prioritization
/// can learn from real deltas rather than guesses.
model OperatorOutcome {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  memoryId       String

  // What moved
  trafficDelta    Float?
  ctrDelta        Float?
  rankingDelta    Float?
  conversionDelta Float?
  revenueDelta    Float?

  // Time window covered by the observation
  windowStart DateTime
  windowEnd   DateTime

  notes     String?
  createdAt DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memory       OperatorMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([memoryId])
}

/// Normalized candidate row. Every source system (crawl, decision engine,
/// graph, gap analysis, GSC, GA4, competitors, decay, schema gaps, WordPress
/// opportunities, user-created, campaigns) writes into this shape so the
/// Operator can dedupe, consolidate, and rank uniformly.
model OperatorCandidate {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  // Source provenance
  sourceSystem   String // graph | decision_engine | gap_analysis | crawl | gsc | ga4 | competitor | decay | schema | wordpress | user | campaign
  sourceRecordId String?
  category       String // money_page | internal_link | schema | content_gap | technical | authority | competitor | campaign …
  actionType     String // canonical action verb, e.g. add_faq_schema, expand_content, add_internal_link

  // Targets
  primaryPageUrl   String
  affectedPageUrls String[] @default([])

  // Business linkage
  businessObjective String?
  moneyPageUrl      String?

  // Evidence + scores (Json blobs so shape can evolve)
  evidence       Json? // graph paths, GSC deltas, competitor changes…
  decisionScores Json? // { businessValue, seoOpportunity, industryScore, … }

  // Effort + risk
  estimatedMinutes     Int      @default(60)
  timeToWin            String? // "Short Term" | "Medium Term" | "Long Term"
  risk                 String   @default("low") // low | medium | high
  confidence           Float    @default(0.7)
  dependencies         String[] @default([])
  deploymentCapability String? // wordpress | custom_html | manual | none

  // Deduplication
  dedupeKey        String // (projectId, category, actionType, primaryPageUrl) canonicalized
  consolidatedFrom String[] @default([]) // candidate ids that were merged in
  supersedesId     String?
  supersededById   String?

  // Lifecycle
  status             String    @default("new") // new | recommended | suppressed | superseded | expired
  createdAt          DateTime  @default(now())
  lastRecalculatedAt DateTime  @default(now())
  expiresAt          DateTime?

  // Denormalized for fast display
  headline  String?
  reasoning Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, dedupeKey])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([primaryPageUrl])
  @@index([projectId, status])
}

/// Append-only event log for the Operator so users can trace every promotion,
/// demotion, suppression, mission change, learning adjustment and conflict.
model OperatorEvent {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  kind    String // candidate_discovered | candidate_consolidated | candidate_promoted | candidate_demoted | candidate_suppressed | mission_selected | mission_changed | recommendation_accepted | recommendation_rejected | recommendation_deferred | action_completed | outcome_verified | learning_adjustment_made | conflict_detected | data_became_stale | recommendation_expired
  summary String
  payload Json?

  candidateId String?
  memoryId    String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([kind])
  @@index([projectId, createdAt])
}

/// Per-user (or project-default) learned preferences. The Operator adjusts
/// ranking based on these but never silently overrides the active business
/// objective. Rows are project + optionally user scoped.
model OperatorPreference {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  userId         String? // null = project-default preference

  category    String // "add_faq_schema", "content_rewrite", "internal_link", …
  signal      String // accept | reject | defer | ignore | prefer_time_window
  weightDelta Float  @default(0) // -1.0 … +1.0 additive rank nudge
  samples     Int    @default(0) // how many observations feed this preference
  detail      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, category, signal])
  @@index([organizationId])
  @@index([projectId])
}

/// Multi-step action plan for compound recommendations. Bounded — the plan
/// itself is short and each step carries its own owner + dependency + risk +
/// deployment method + verification method.
model OperatorActionPlan {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  candidateId    String
  memoryId       String?

  headline     String
  totalMinutes Int    @default(0)
  status       String @default("pending") // pending | in_progress | completed | failed | rolled_back

  steps Json // OperatorPlanStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([candidateId])
  @@index([status])
}

/// Per-user (or project-default) notification preferences.
model OperatorNotificationPref {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  userId         String?

  channel  String // in_app | email_digest
  category String // new_primary_mission | critical_issue | mission_changed | deployment_failed | verification_succeeded | recommendation_returned | strong_opportunity | competitor_risk | more_evidence_required
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, channel, category])
  @@index([organizationId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERATOR PHASE 8.2 — SELF-REVIEW & DECISION VALIDATION
// ─────────────────────────────────────────────────────────────────────────────

/// Tracks the self-review cycle for every shortlist. Records original recommendations,
/// review findings (promote/demote/merge/replace/suppress), consultant review, and final recommendations.
model OperatorReviewCycle {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  originalShortlist Json // OperatorShortlist before review
  reviewDecisions   Json // ReviewDecision[] (promote/demote/merge/replace/suppress/escalate)
  consultantReview  Json? // ConsultantReview (would consultant agree?)
  finalShortlist    Json // OperatorShortlist after review

  agreements    Int @default(0) // how many recommendations agreed with consultant mode
  disagreements Int @default(0)
  promotions    Int @default(0) // count by decision type
  demotions     Int @default(0)
  merges        Int @default(0)
  replacements  Int @default(0)
  suppressions  Int @default(0)
  escalations   Int @default(0)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([createdAt])
}

/// Alternative strategies generated by the Operator. For each recommendation,
/// the Operator generates 3 strategies and explains why one was chosen.
model OperatorStrategy {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  candidateId    String

  strategyType  String // "fastest_roi" | "long_term_authority" | "lowest_risk"
  headline      String
  steps         Json // Multi-step action sequence
  expectedROI   Float   @default(0)
  timelineWeeks Int     @default(0)
  riskLevel     String // "low" | "medium" | "high"
  rationale     String
  isRecommended Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([candidateId])
  @@index([isRecommended])
}

/// Why-not analysis: explains why competing recommendations were rejected.
model OperatorWhyNot {
  id                  String @id @default(cuid())
  organizationId      String
  projectId           String
  selectedCandidateId String
  rejectedCandidateId String

  reason      String // "lower_business_value" | "missing_prerequisite" | "already_performing_well" | "recently_optimized" | "low_confidence" | "better_opportunity" | "waiting_for_data" | "objective_mismatch"
  explanation String
  magnitude   Float  @default(0) // e.g., score difference

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([selectedCandidateId])
}

/// Confidence audit for every recommendation. Tracks evidence quality,
/// data freshness, assumptions, unknown variables, and missing data.
model OperatorConfidenceAudit {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  candidateId    String

  overallConfidence  Float @default(0.5)
  evidenceQuality    Float @default(0.5)
  dataFreshness      Float @default(0.5)
  dataSourceCoverage Float @default(0.5)

  assumptions       Json // string[]
  unknownVariables  Json // string[]
  missingData       Json // string[]
  reasonsForCaution Json // string[]

  crawlIncomplete       Boolean @default(false)
  weakEntityDetection   Boolean @default(false)
  noGSC                 Boolean @default(false)
  noGA4                 Boolean @default(false)
  weakGraphEvidence     Boolean @default(false)
  limitedHistoricalData Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([candidateId])
}

/// Opportunity cost analysis: what are we giving up by choosing this recommendation?
model OperatorOpportunityCost {
  id                  String  @id @default(cuid())
  organizationId      String
  projectId           String
  selectedCandidateId String
  delayedCandidateId  String?

  description    String
  costMagnitude  String // "low" | "medium" | "high"
  estimatedDelay Int    @default(0) // days
  businessImpact String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
}

/// Quality metrics for the Operator itself. Tracks acceptance rate, success rate, etc.
model OperatorQualityMetric {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?

  metricType String // "operator_agreement" | "consultant_agreement" | "acceptance_rate" | "completion_rate" | "success_rate" | "false_positive_rate" | "regret_rate" | "replacement_rate"
  value      Float  @default(0)
  samples    Int    @default(0)
  period     String @default("all_time") // "week" | "month" | "quarter" | "all_time"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([metricType])
  @@index([period])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 9: EXECUTION ENGINE
// ─────────────────────────────────────────────────────────────────────────────

/// Execution plans derived from recommendations. Stores workflow definition and steps.
model ExecutionPlan {
  id               String  @id @default(cuid())
  organizationId   String
  projectId        String
  recommendationId String? // Reference to original recommendation if from Operator

  title         String // e.g., "Update title on Service Page"
  description   String?
  executionType String // "update_title" | "add_schema" | "improve_links" | "create_section" | "refresh_content" | "repair_canonical" | "repair_redirect" | "merge_content" | "add_images" | "improve_headings" | "custom"

  pageUrl          String // Target page URL
  steps            Json // ExecutionStep[] - ordered workflow steps
  expectedInputs   Json // What data is needed
  expectedOutputs  Json // What will change
  dependencies     Json // Other pages/tasks that must complete first
  rollbackStrategy String // "none" | "restore_backup" | "reverse_steps" | "manual"

  estimatedTimeMinutes Int    @default(0)
  estimatedRiskLevel   String @default("medium") // "low" | "medium" | "high"
  expectedROI          Float  @default(0) // Expected business return percentage
  expectedConfidence   Float  @default(0.5) // 0-1 confidence in success

  status         String @default("draft") // "draft" | "pending_approval" | "approved" | "executing" | "completed" | "failed" | "rolled_back"
  approvalPolicy String @default("manual") // "automatic" | "manual" | "two_person" | "admin" | "enterprise"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvals     ExecutionApproval[]
  deployment    ExecutionDeployment?
  verifications ExecutionVerification[]
  outcome       ExecutionOutcome?
  jobs          ExecutionJob[]

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([executionType])
  @@index([approvalPolicy])
}

/// Approval workflows for execution plans.
model ExecutionApproval {
  id              String @id @default(cuid())
  organizationId  String
  executionPlanId String
  approverUserId  String

  status     String // "pending" | "approved" | "rejected"
  reasoning  String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionPlan ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)
  approverUser  User          @relation(fields: [approverUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([executionPlanId])
  @@index([approverUserId])
  @@index([status])
}

/// Deployment execution records.
model ExecutionDeployment {
  id               String @id @default(cuid())
  organizationId   String
  executionPlanId  String @unique
  deployedByUserId String

  dryRunStatus String? // null | "pending" | "success" | "failed"
  dryRunResult Json? // Dry run preview/validation results

  actualStatus String @default("pending") // "pending" | "in_progress" | "success" | "partial_failure" | "failed"
  attemptCount Int    @default(0)
  maxAttempts  Int    @default(3)

  changes  Json // Actual changes made (before/after diffs)
  errors   String[]
  warnings String[]

  rollbackExecuted Boolean @default(false)
  rollbackReason   String?

  deployedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionPlan  ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)
  deployedByUser User          @relation(fields: [deployedByUserId], references: [id], onDelete: Cascade)
  rollbackSnapshot ExecutionRollbackSnapshot?

  @@index([organizationId])
  @@index([executionPlanId])
  @@index([actualStatus])
  @@index([deployedAt])
}

/// Post-deployment verification results.
model ExecutionVerification {
  id              String  @id @default(cuid())
  organizationId  String
  executionPlanId String
  deploymentId    String?

  verifyType String // "page_updated" | "schema_valid" | "title_changed" | "links_added" | "canonical_fixed" | "indexability" | "html_valid" | "all"
  status     String // "pending" | "verifying" | "success" | "failed"
  details    Json // Verification details and checks

  passedChecks      String[]
  failedChecks      String[]
  automatedRollback Boolean  @default(false)

  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionPlan ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([executionPlanId])
  @@index([status])
  @@index([verifyType])
}

/// Business outcome tracking after deployment.
model ExecutionOutcome {
  id              String  @id @default(cuid())
  organizationId  String
  projectId       String
  executionPlanId String  @unique
  deploymentId    String?

  // Measured outcomes (null if data not yet available)
  rankingsImproved Boolean?
  rankingsDelta    Float? // Position change (-2, +1, etc)

  ctrImproved Boolean?
  ctrDelta    Float? // CTR change (0.05 = +5%)

  trafficImproved Boolean?
  trafficDelta    Int? // Additional visits

  conversionsImproved Boolean?
  conversionsDelta    Float? // Conversion rate change

  aiReadinessImproved Boolean?
  aiReadinessDelta    Float? // Readability/schema/semantic score change

  coreWebVitalsChange Json? // LCP/FID/CLS changes

  measurementPeriodDays Int? // How many days of data collected
  measurementStartDate  DateTime?
  measurementEndDate    DateTime?

  status String  @default("tracking") // "tracking" | "insufficient_data" | "complete"
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executionPlan ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([executionPlanId])
  @@index([status])
}

/// Execution history audit trail.
model ExecutionHistory {
  id              String  @id @default(cuid())
  organizationId  String
  projectId       String
  executionPlanId String?

  action    String // "created" | "approved" | "rejected" | "deployed" | "verified" | "rolled_back" | "outcome_tracked"
  actor     String // User email or system
  details   Json // Action-specific details
  timestamp DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([executionPlanId])
  @@index([action])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 9.1: PRODUCTION EXECUTION ENGINE
// ─────────────────────────────────────────────────────────────────────────────

/// Background execution jobs for safe, resumable work.
model ExecutionJob {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  executionPlanId   String
  campaignId        String?  // Null if standalone, set if part of campaign

  jobType           String   // "execute" | "verify" | "rollback"
  status            String   @default("queued") // "queued" | "running" | "success" | "failed" | "retrying" | "paused"
  priority          Int      @default(0)

  attemptCount      Int      @default(0)
  maxAttempts       Int      @default(3)
  lastAttemptAt     DateTime?
  nextRetryAt       DateTime?

  payload           Json     // Job-specific data
  result            Json?    // Execution result
  error             String?

  queuedAt          DateTime @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executionPlan     ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([executionPlanId])
  @@index([campaignId])
  @@index([status])
  @@index([priority])
  @@index([queuedAt])
}

/// Campaign execution groups multiple actions as one unit.
model ExecutionCampaign {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String

  name              String
  description       String?
  campaignType      String   // "technical_cleanup" | "internal_linking" | "schema_rollout" | "ctr_improvement" | "service_refresh" | "custom"

  status            String   @default("draft") // "draft" | "queued" | "running" | "paused" | "completed" | "rolled_back" | "failed"
  executionPlanIds  String[] // Ordered list of plan IDs

  approvedAt        DateTime?
  approvedByUserId  String?
  startedAt         DateTime?
  completedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedByUser    User? @relation(fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([campaignType])
}

/// Rollback snapshots to enable reversibility.
model ExecutionRollbackSnapshot {
  id                      String   @id @default(cuid())
  organizationId          String
  executionDeploymentId   String   @unique

  previousValue           Json     // Full previous state
  newValue                Json     // Full new state
  changeType              String   // "title" | "meta_description" | "canonical" | "schema" | "internal_link" | etc
  pageUrl                 String

  rollbackExecutedAt      DateTime?
  rollbackStatus          String?  // "pending" | "success" | "failed"
  rollbackError           String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deployment              ExecutionDeployment @relation(fields: [executionDeploymentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([executionDeploymentId])
  @@index([changeType])
  @@index([pageUrl])
}

/// Detailed audit trail for all execution operations.
model ExecutionAuditLog {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  executionPlanId   String?
  deploymentId      String?

  operation         String   // "created_plan" | "approved" | "rejected" | "executed" | "verified" | "rolled_back" | "measured"
  actor             String   // User email or "system"
  actorUserId       String?

  beforeState       Json?    // Full state before
  afterState        Json?    // Full state after
  changes           Json     // Detailed changes
  reason            String?  // Why this operation

  verified          Boolean  @default(false)
  verificationResult Json?

  timestamp         DateTime @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor_user        User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([executionPlanId])
  @@index([operation])
  @@index([actor])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 10.1: AUTONOMOUS OPERATIONS VALIDATION & SAFETY
// ─────────────────────────────────────────────────────────────────────────────

/// Autonomy mode for a project (fail-closed by default)
model AutonomyMode {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String

  mode              String   @default("disabled") // "disabled" | "simulation_only" | "approval_required" | "low_risk_autonomy"
  enabledAt         DateTime?
  enabledByUserId   String?
  disabledAt        DateTime?
  disabledByUserId  String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabledByUser     User?        @relation("autonomy_enabled", fields: [enabledByUserId], references: [id], onDelete: SetNull)
  disabledByUser    User?        @relation("autonomy_disabled", fields: [disabledByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, projectId])
  @@index([organizationId])
  @@index([projectId])
  @@index([mode])
}

/// Emergency stop (global, organization, or project level)
model EmergencyStop {
  id                String   @id @default(cuid())
  organizationId    String?
  projectId         String?

  level             String   // "global" | "organization" | "project"
  reason            String
  activatedAt       DateTime @default(now())
  activatedByUserId String
  deactivatedAt     DateTime?
  deactivatedByUserId String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activatedByUser   User          @relation("stop_activated", fields: [activatedByUserId], references: [id], onDelete: Restrict)
  deactivatedByUser User?         @relation("stop_deactivated", fields: [deactivatedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([level])
  @@index([activatedAt])
}

/// Policy rules for autonomy decisions (hierarchical: global → org → project → recommendation)
model AutonomyPolicy {
  id                String   @id @default(cuid())
  organizationId    String?  // null = global policy
  projectId         String?  // null = not project-specific

  level             String   // "global" | "organization" | "project"
  executionType     String   // "missing_schema" | "broken_links" | etc., or "*" for all

  // Permission rules
  allowAutonomous   Boolean  @default(false)
  requireApproval   Boolean  @default(true)
  minRiskThreshold  String   @default("very_low") // "very_low" | "low" | "medium" | "high" | "critical"
  minConfidence     Float    @default(0.85) // 0.0-1.0
  dataFreshnessHours Int    @default(24)

  // Operational limits
  maxChangesPerDay  Int      @default(100)
  maxPagesPerDay    Int      @default(50)
  maxConcurrent     Int      @default(10)
  businessHoursOnly Boolean  @default(false)

  // Restrictions
  forbiddenPageTypes String[] // JSON array of protected page types
  requireRollbackSupport Boolean @default(true)
  requireVerification Boolean @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdByUserId   String?

  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser     User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([level])
  @@index([executionType])
}

/// Safety contract for each execution type (immutable specification of autonomy terms)
model ExecutionContract {
  id                String   @id @default(cuid())

  executionType     String   @unique // "missing_schema" | "broken_links" | etc.
  version           Int      @default(1)

  // Contract terms
  maxRiskLevel      String   // "very_low" | "low"
  minConfidence     Float    @default(0.85)
  dataFreshness     Int      @default(24) // hours

  // Preconditions (all must be true)
  requiresRollbackSupport Boolean @default(true)
  requiresVerification Boolean @default(true)
  requiresWordPressConnection Boolean @default(true)

  // Forbidden scenarios (must not be true)
  forbiddenPageTypes String[] // JSON array of page types that cannot be modified
  forbiddenPlugins  String[] // JSON array of incompatible plugins
  maxBatchSize      Int      @default(10)

  // Rollback and verification methods
  rollbackMethod    String   // "state_restore" | "api_revert" | etc.
  verificationMethod String  // "html_parse" | "api_read" | etc.
  autoRetryCount    Int      @default(3)

  // Mutation scope (what can change)
  allowedMutations  String[] // JSON array of allowed field changes
  maxMutationScope  String   // "target_field" | "post_metadata" | etc.

  // Escalation
  escalateOnFailure Boolean @default(true)
  escalateOnHighRisk Boolean @default(true)

  activatedAt       DateTime @default(now())
  retiredAt         DateTime?

  @@index([executionType])
  @@index([activatedAt])
}

/// Immutable decision log (every autonomous evaluation recorded here)
model AutonomyDecisionLog {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String

  // Candidate information
  candidateId       String
  executionType     String
  recommendationId  String?

  // Policy evaluation
  globalPolicy      Json
  organizationPolicy Json?
  projectPolicy     Json?
  recommendationPolicy Json?

  // Risk assessment
  riskLevel         String   // "very_low" | "low" | "medium" | "high" | "critical"
  riskFactors       Json     // Detailed risk inputs
  riskScore         Float    // 0.0-1.0

  // Confidence assessment
  confidence        Float    // 0.0-1.0
  confidenceFactors Json

  // Data freshness
  lastDataUpdate    DateTime
  dataFreshnessHours Int

  // Business context
  businessContext   Json     // Money-page status, time-of-day, daily change count, etc.

  // Safety conditions
  rollbackAvailable Boolean  @default(true)
  verificationAvailable Boolean @default(true)
  wordPressHealthy  Boolean  @default(true)
  pluginCompatible  Boolean  @default(true)
  emergencyStopActive Boolean @default(false)

  // Decision result
  decision          String   // "approved" | "blocked" | "deferred" | "requires_approval"
  reason            String   // Detailed explanation
  decisionMaker     String   // "policy_engine" | "operator" | "user"
  decidedByUserId   String?

  // Execution plan
  executionPlan     Json?    // What would be executed
  verificationPlan  Json?    // How it would be verified
  rollbackPlan      Json?    // How it would be rolled back

  // Lifecycle
  executedAt        DateTime?
  executionResult   String?  // "success" | "verification_failed" | "rollback_failed"
  executionError    String?
  verificationResult Json?
  rollbackResult    String?

  // Outcome tracking
  outcomeStatus     String   @default("awaiting_data") // "awaiting_data" | "no_change" | "positive" | "negative" | "inconclusive" | "reversed" | "rolled_back"
  outcomeMetrics    Json?    // CTR, impressions, rankings, etc.

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decidedByUser     User?        @relation(fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([executionType])
  @@index([decision])
  @@index([createdAt])
  @@index([outcomeStatus])
}

/// Autonomy quality metrics (aggregated from decision logs)
model AutonomyMetrics {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String?  // null = organization-level aggregate

  period            String   @default("daily") // "daily" | "weekly" | "monthly"
  date              DateTime

  // Evaluation metrics
  evaluationsPerformed Int @default(0)
  simulatedApprovals Int @default(0)
  realExecutions    Int @default(0)
  blockedActions    Int @default(0)
  approvalRequired  Int @default(0)
  deferred          Int @default(0)

  // Execution metrics
  successfulExecutions Int @default(0)
  verificationFailures Int @default(0)
  automaticRollbacks Int @default(0)
  rollbackFailures  Int @default(0)
  userReversals     Int @default(0)

  // Quality metrics
  successRate       Float    @default(0.0)
  verificationFailureRate Float @default(0.0)
  rollbackRate      Float    @default(0.0)
  falseApprovalRate Float    @default(0.0)
  falseRejectionRate Float    @default(0.0)

  // Performance
  meanExecutionTime Int      @default(0) // milliseconds
  meanVerificationTime Int   @default(0)
  meanRollbackTime  Int      @default(0)
  maxQueueLatency   Int      @default(0)

  // Safety
  safetyIncidents   Int      @default(0)
  criticalDefects   Int      @default(0)
  highDefects       Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId, period, date])
  @@index([organizationId])
  @@index([projectId])
  @@index([date])
}

