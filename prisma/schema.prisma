  updatedAt    DateTime @updatedAt

  organization Organization @relation("PagePriorities", fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([auditId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([auditId])
  @@index([priorityScore])
  @@index([priorityRank])
}

model RecommendationDecision {
  id                 String @id @default(cuid())
  organizationId     String
  projectId          String
  pageUrl            String
  recommendationType String

  // Scoring
  businessValue          Int
  seoOpportunity         Int
  expectedBusinessReturn Json
  difficulty             Int // 1-10
  riskLevel              String // "Very Low", "Low", "Medium", "High", "Very High"
  riskExplanation        String?
  estimatedTime          Int // minutes
  timeToWin              String // "Immediate", "Short Term", etc
  dependencies           String[]

  // Explainability
  whyThis         String
  whyNow          String
  whyThisPage     String
  whyThisPriority String
  confidence      Float // 0-1
  dataSupporting  Json

