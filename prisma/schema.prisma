  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromPageUrl, toPageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([priority])
  @@index([isImplemented])
}

model ContentDecayAlert {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  pageUrl           String

  // What's declining
  decayType         String   // traffic_loss, ranking_loss, ctr_decline, impressions_decline
  severity          String   @default("medium") // high, medium, low
  decayPercentage   Float

  // Timeline
  detectedAt        DateTime @default(now())
  decayStartedAt    DateTime?
  lastMeasuredAt    DateTime?
  trend30d          Float?

  // Context
  currentValue      Float
  previousValue     Float
  potentialCause    String[]

  // Resolution
  isResolved        Boolean  @default(false)
  resolvedBy        String?  // Content refresh, new internal links, etc
  resolvedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([severity])
  @@index([decayType])
  @@index([isResolved])
}
