model ContentInventory {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  pageUrl           String   // Unique per project

  // Content classification
  contentType       String   // page, blog, service, location, product, landing, faq, resource
  primaryTopic      String?
  primaryEntities   String[] @default([]) // JSON: entity names

  // Page metrics
  wordCount         Int      @default(0)
  imageCount        Int      @default(0)
  lastModified      DateTime?
  indexStatus       String   @default("unknown") // indexed, not_indexed, blocked, noindex, crawled_not_indexed
  canonical         String?

  // Link structure
  internalLinkCount Int      @default(0)
  externalLinkCount Int      @default(0)
  linksToThisPage   Int      @default(0)

  // Schema and structure
  hasSchema         Boolean  @default(false)
  schemaTypes       String[] @default([])
  targetKeywords    String[] @default([]) // From GSC or manual

  // Performance data
  gscImpressions    Int      @default(0)
  gscClicks         Int      @default(0)
  gscAverageCtr     Float    @default(0)
  gscAveragePosition Float   @default(0)
  ga4Sessions       Int      @default(0)
  ga4Pageviews      Int      @default(0)
  ga4Conversions    Int      @default(0)

  // Business context
  businessValue     Float    @default(0)
  decisionEngineScore Float  @default(0)
  isMoneyPage       Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  metrics           ContentMetrics?
  refreshOpportunity ContentRefreshOpportunity?
  gaps              ContentGapAnalysis[]

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([contentType])
  @@index([indexStatus])
  @@index([isMoneyPage])
  @@index([updatedAt])
}

model ContentMetrics {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  pageUrl           String
  inventoryId       String   @unique // One-to-one with ContentInventory

  // Quality scores (0-100)
  qualityScore      Int      @default(0)
  qualityExplanation String?

  freshnessScore    Int      @default(0)
  freshnessExplanation String?

  entityCoverageScore Int    @default(0)
  entityExplanation String?

  topicalDepthScore Int      @default(0)
  topicalExplanation String?

  readabilityScore  Int      @default(0)
  readabilityExplanation String?

  seoOptimizationScore Int   @default(0)
  seoExplanation    String?

  aiReadinessScore  Int      @default(0)
  aiReadinessExplanation String?

  conversionReadinessScore Int @default(0)
  conversionExplanation String?

  businessValueScore Int     @default(0)
  businessExplanation String?

  // Overall
  opportunityScore  Int      @default(0)
  overallScore      Int      @default(0)

  calculatedAt      DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory         ContentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([opportunityScore])
  @@index([overallScore])
}

model ContentGapAnalysis {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  inventoryId       String? // Reference to related page if exists

  gapType           String   // missing_service, missing_location, missing_faq, missing_comparison, missing_support, missing_trust, missing_cluster
  description       String
  priority          String   @default("medium") // high, medium, low
  expectedImpact    String? // "high", "medium", "low" + business value estimate

  // What should be created
  recommendedPageType String? // service_page, location_page, faq, comparison_page, etc
  suggestedTopic    String?
  suggestedTitle    String?

  // Context for generation
  relatedKeywords   String[] @default([])
  relatedServices   String[] @default([])
  relatedLocations  String[] @default([])
  competitorExamples String[] @default([]) // URLs from competitors doing this well

  // Why this matters
  rationale         String   // Explain why this gap exists and why it matters
  estimatedTrafficPotential Int @default(0)
  businessObjectiveAlignment String? // How this supports the 90-day objective

  isAddressed       Boolean  @default(false)
  addressedBy       String?  // Content brief or generated content ID
  addressedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory         ContentInventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([gapType])
  @@index([priority])
  @@index([isAddressed])
}

model ContentRefreshOpportunity {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  pageUrl           String
  inventoryId       String   @unique // One-to-one with ContentInventory

  // Why refresh is needed
  refreshReasons    String[] // traffic_decline, ctr_decline, ranking_decline, outdated_content, thin_content, weak_entities, missing_schema, competitor_overtake, outdated_stats
  trafficTrend30d   Float    @default(0) // % change
  rankingTrend30d   Float    @default(0) // position change
  ctrTrend30d       Float    @default(0) // % change

  // Timeline
  lastRefreshed     DateTime?
  suggestedRefreshDate DateTime?
  daysStale         Int      @default(0)

  // Potential
  estimatedPotential Float   @default(0) // Traffic recovery potential
  priority          String   @default("medium") // high, medium, low

  // What to improve
  suggestedImprovements String[]

  // Status
  isScheduled       Boolean  @default(false)
  refreshInitiatedAt DateTime?
  refreshCompletedAt DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory         ContentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([priority])
  @@index([isScheduled])
}

model ContentBrief {
