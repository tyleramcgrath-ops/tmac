  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([businessProfileId])
  @@index([createdAt])
}

model CampaignTemplate {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String

  name              String
  description       String?
  industry          String?  // References IndustryPlaybook.industry if set
  templateType      String   // "practice_area_growth", "location_expansion", "category_growth", etc

  // What this campaign focuses on
  pageTypePriorities String[] // JSON: [{type, weight}]
  technicalFocus    String[]
  contentFocus      String[]

