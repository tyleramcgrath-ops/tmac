  @@unique([projectId, date])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 7.6: BUSINESS CONTEXT & INDUSTRY PLAYBOOKS
// ─────────────────────────────────────────────────────────────────────────────

model BusinessProfile {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  // Core business info
  businessName  String
  industry      String // law_firm, medical_practice, ecommerce, saas, local_business, etc
  businessModel String // b2b, b2c, local_service, marketplace, subscription, etc
  description   String?

  // Products and services
  primaryServices     String[] // JSON: [{name, value}]
  highestValueService String?
  secondaryServices   String[] @default([])

  // Locations
  primaryLocations   String[] // JSON: [{city, state, country}]
  expansionLocations String[] @default([])
  serveGlobally      Boolean  @default(false)

  // Business metrics (all optional - never invent)
  averageLeadValue     Float?
  averageCustomerValue Float?
  averageOrderValue    Float?
  closeRate            Float? // 0-1

  // Goals and strategy
  targetCustomers          String?
  primaryConversionGoal    String
  secondaryConversionGoals String[] @default([])

  // Seasonal and strategic
  seasonalPriorities String[] @default([]) // References to SeasonalPriority
  businessNotes      String?

  // Current focus
  activeObjective String? // References current BusinessObjective
  objective90Days String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project             Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objectives          BusinessObjective[]
  pageClassifications PageBusinessClassification[]
  conversionGoals     ConversionGoal[]
  seasonalPeriods     SeasonalPriority[]
  versions            BusinessContextVersion[]

  @@unique([organizationId, projectId])
  @@unique([projectId])
  @@index([organizationId])
  @@index([industry])
  @@index([activeObjective])
}

model BusinessObjective {
  id                String @id @default(cuid())
  organizationId    String
  projectId         String
  businessProfileId String

  objectiveType   String // increase_leads, increase_calls, increase_revenue, expand_locations, launch_service, etc
  customObjective String? // For custom objective type
  isActive        Boolean @default(true)

  description  String?
  targetMetric String?
  targetValue  Float?
  targetDate   DateTime?

  // How this objective influences Decision Engine
  priorityPageTypes String[] // Which page types matter for this objective
  priorityServices  String[] @default([])
  priorityLocations String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([businessProfileId])
  @@index([isActive])
}

model IndustryPlaybook {
  id String @id @default(cuid())

  industry    String  @unique // law_firm, medical, dental, hvac, real_estate, saas, ecommerce, etc
  displayName String
  description String?

  // Priority guidance
  importantPageTypes       String[] // Which page types matter most
  importantConversionTypes String[] // lead, call, appointment, purchase, signup, etc
  typicalMoneyPages        String[] // ["service_page", "product_page", "location_page", "pricing_page"]

  // Technical guidance
  recommendedSchema       String[] // ["LocalBusiness", "Product", "Service", etc]
  criticalTechnicalIssues String[] // Which technical issues matter most
  contentOpportunities    String[] // High-value content types

  // Importance scores
  localSeoImportance    Int @default(50) // 0-100
  trustSignalImportance Int @default(50)
  schemaImportance      Int @default(50)

  // Decision Engine weight recommendations
  businessValueWeight  Float @default(0.60)
  seoOpportunityWeight Float @default(0.40)

  // Time estimates
  typicalTimeToWin          String // "immediate", "short_term", "medium_term", "long_term"
  typeicalFirstResultsWeeks Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns CampaignTemplate[]

  @@index([industry])
}

model PageBusinessClassification {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String

  // Business classification
  businessClassification String // mission_critical, high_value, supporting, informational, utility, ignore
  manualOverride         Boolean   @default(false)
  overriddenBy           String? // User ID who set override
  overriddenAt           DateTime?

  // Supporting data
  relatedService  String?
  relatedProduct  String?
  relatedLocation String?

  // Metrics
  monthlyRevenue     Float?
  monthlyConversions Int?
  conversionValue    Float?

  rationale String? // Why this classification

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile @relation(fields: [organizationId, projectId], references: [organizationId, projectId], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([businessClassification])
}

model ConversionGoal {
  id                String @id @default(cuid())
  organizationId    String
  projectId         String
  businessProfileId String

  goalName    String
  goalType    String // lead, call, appointment, purchase, signup, download, etc
  description String?

  // Tracking
  conversionUrl     String?
  trackingParameter String?

  // Value
  estimatedValue Float?
  priority       Int    @default(1) // 1 = primary, 2 = secondary, etc

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([businessProfileId])
  @@index([goalType])
}

model SeasonalPriority {
  id                String @id @default(cuid())
  organizationId    String
  projectId         String
  businessProfileId String

  name        String // "tax_season", "holiday_sales", "summer_travel", etc
  description String?

  startDate           DateTime
  endDate             DateTime
  preparationLeadDays Int      @default(30) // Days before season to increase priority

  // What matters during this season
  relevantServices String[] @default([])
  relevantProducts String[] @default([])
  priorityPageUrls String[] @default([])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([businessProfileId])
  @@index([startDate])
}

model BusinessContextVersion {
  id                String @id @default(cuid())
  organizationId    String
  projectId         String
  businessProfileId String

  changeType    String // industry_changed, objective_changed, service_added, etc
  previousValue String? // JSON of what changed
  newValue      String? // JSON of what changed to

  changedBy String? // User ID
  reason    String?

  impactedRecommendations Int @default(0)

  createdAt DateTime @default(now())

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([businessProfileId])
  @@index([createdAt])
}

model CampaignTemplate {
  id             String @id @default(cuid())
  organizationId String
  projectId      String

  name         String
  description  String?
  industry     String? // References IndustryPlaybook.industry if set
  templateType String // "practice_area_growth", "location_expansion", "category_growth", etc

  // What this campaign focuses on
  pageTypePriorities String[] // JSON: [{type, weight}]
  technicalFocus     String[]
  contentFocus       String[]

  // Decision Engine adjustments for this campaign
  businessValueWeightAdjustment  Float @default(1.0)
  seoOpportunityWeightAdjustment Float @default(1.0)

  // Expected results
  estimatedTimeWeeks Int?
  estimatedImpact    String? // "high", "medium", "low"

  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  playbook     IndustryPlaybook? @relation(fields: [industry], references: [industry], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([industry])
  @@index([templateType])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 7.7: AI CONTENT & OPTIMIZATION ENGINE
// ─────────────────────────────────────────────────────────────────────────────

model ContentInventory {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String // Unique per project

  // Content classification
  contentType     String // page, blog, service, location, product, landing, faq, resource
  primaryTopic    String?
  primaryEntities String[] @default([]) // JSON: entity names

  // Page metrics
  wordCount    Int       @default(0)
  imageCount   Int       @default(0)
  lastModified DateTime?
  indexStatus  String    @default("unknown") // indexed, not_indexed, blocked, noindex, crawled_not_indexed
  canonical    String?

  // Link structure
  internalLinkCount Int @default(0)
  externalLinkCount Int @default(0)
  linksToThisPage   Int @default(0)

  // Schema and structure
  hasSchema      Boolean  @default(false)
  schemaTypes    String[] @default([])
  targetKeywords String[] @default([]) // From GSC or manual

  // Performance data
  gscImpressions     Int   @default(0)
  gscClicks          Int   @default(0)
  gscAverageCtr      Float @default(0)
  gscAveragePosition Float @default(0)
  ga4Sessions        Int   @default(0)
  ga4Pageviews       Int   @default(0)
  ga4Conversions     Int   @default(0)

  // Business context
  businessValue       Float   @default(0)
  decisionEngineScore Float   @default(0)
  isMoneyPage         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  metrics            ContentMetrics?
  refreshOpportunity ContentRefreshOpportunity?
  gaps               ContentGapAnalysis[]

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([contentType])
  @@index([indexStatus])
  @@index([isMoneyPage])
  @@index([updatedAt])
}

model ContentMetrics {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String
  inventoryId    String @unique // One-to-one with ContentInventory

  // Quality scores (0-100)
  qualityScore       Int     @default(0)
  qualityExplanation String?

  freshnessScore       Int     @default(0)
  freshnessExplanation String?

  entityCoverageScore Int     @default(0)
  entityExplanation   String?

  topicalDepthScore  Int     @default(0)
  topicalExplanation String?

  readabilityScore       Int     @default(0)
  readabilityExplanation String?

  seoOptimizationScore Int     @default(0)
  seoExplanation       String?

  aiReadinessScore       Int     @default(0)
  aiReadinessExplanation String?

  conversionReadinessScore Int     @default(0)
  conversionExplanation    String?

  businessValueScore  Int     @default(0)
  businessExplanation String?

  // Overall
  opportunityScore Int @default(0)
  overallScore     Int @default(0)

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory    ContentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([opportunityScore])
  @@index([overallScore])
}

model ContentGapAnalysis {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  inventoryId    String? // Reference to related page if exists

  gapType        String // missing_service, missing_location, missing_faq, missing_comparison, missing_support, missing_trust, missing_cluster
  description    String
  priority       String  @default("medium") // high, medium, low
  expectedImpact String? // "high", "medium", "low" + business value estimate

  // What should be created
  recommendedPageType String? // service_page, location_page, faq, comparison_page, etc
  suggestedTopic      String?
  suggestedTitle      String?

  // Context for generation
  relatedKeywords    String[] @default([])
  relatedServices    String[] @default([])
  relatedLocations   String[] @default([])
  competitorExamples String[] @default([]) // URLs from competitors doing this well

  // Why this matters
  rationale                  String // Explain why this gap exists and why it matters
  estimatedTrafficPotential  Int     @default(0)
  businessObjectiveAlignment String? // How this supports the 90-day objective

  isAddressed Boolean   @default(false)
  addressedBy String? // Content brief or generated content ID
  addressedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory    ContentInventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([gapType])
  @@index([priority])
  @@index([isAddressed])
}

model ContentRefreshOpportunity {
  id             String @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String
  inventoryId    String @unique // One-to-one with ContentInventory

  // Why refresh is needed
  refreshReasons  String[] // traffic_decline, ctr_decline, ranking_decline, outdated_content, thin_content, weak_entities, missing_schema, competitor_overtake, outdated_stats
  trafficTrend30d Float    @default(0) // % change
  rankingTrend30d Float    @default(0) // position change
  ctrTrend30d     Float    @default(0) // % change

  // Timeline
  lastRefreshed        DateTime?
  suggestedRefreshDate DateTime?
  daysStale            Int       @default(0)

  // Potential
  estimatedPotential Float  @default(0) // Traffic recovery potential
  priority           String @default("medium") // high, medium, low

  // What to improve
  suggestedImprovements String[]

  // Status
  isScheduled        Boolean   @default(false)
  refreshInitiatedAt DateTime?
  refreshCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventory    ContentInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([priority])
  @@index([isScheduled])
}

model ContentBrief {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String
  pageUrl        String? // NULL for new pages, set for existing page rewrites

  // Purpose and audience
  purpose           String // increase_rankings, capture_traffic, improve_conversions, build_authority, support_product, etc
