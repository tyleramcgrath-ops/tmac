model BusinessContextVersion {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String
  businessProfileId String

  changeType        String   // industry_changed, objective_changed, service_added, etc
  previousValue     String?  // JSON of what changed
  newValue          String?  // JSON of what changed to

