// Production-ready multi-tenant SaaS schema
// Implements: multi-tenancy, RBAC, audit logging, encrypted credentials

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTHENTICATION & USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    DateTime?
  name             String?
  passwordHash     String?  // bcrypt hash, nullable for OAuth-only accounts
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Sessions and authentication
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  // Organizational relationships
  organizationMemberships  OrganizationMember[]

  // Audit trail
  auditLogs                AuditLog[]

  @@index([email])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZATIONS & TEAMS
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique  // For URL: example.tmac.com
  logoUrl          String?
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Team & access control
  members          OrganizationMember[]
  teamInvitations  TeamInvitation[]

  // Organization data
  projects         Project[]
  audits           Audit[]
  workItems        WorkItem[]
  events           Event[]
  auditLogs        AuditLog[]
  recommendations  Recommendation[]
  competitors      Competitor[]
  deployments      Deployment[]

  // Integrations (org-level)
  oauthCredentials OAuthCredential[]
  googleSearchConsoleMetrics GoogleSearchConsoleMetric[]
  googleAnalytics4Metrics GoogleAnalytics4Metric[]

  // Decision Engine (org-level)
  pageClassifications PageClassification[] @relation("PageClassifications")
  pageSignals         PageSignals[] @relation("PageSignals")
  businessValueScores BusinessValueScore[] @relation("BusinessValueScores")
  seoOpportunityScores SEOOpportunityScore[] @relation("SEOOpportunityScores")
  pagePriorities      PagePriority[] @relation("PagePriorities")
  recommendationDecisions RecommendationDecision[] @relation("RecommendationDecisions")
  dailyMissions       DailyMission[] @relation("DailyMissions")
  businessContext     BusinessContext? @relation("BusinessContext")

  @@index([slug])
  @@index([createdAt])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   // 'owner', 'admin', 'manager', 'analyst', 'viewer'
  invitedAt      DateTime @default(now())
  joinedAt       DateTime?
  removedAt      DateTime?
  invitedBy      String?  // User ID who sent the invitation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
}

model TeamInvitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   // 'admin', 'manager', 'analyst', 'viewer'
  token          String   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  userId         String?  // Populated when invitation is accepted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECTS (Organization-scoped)
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  domain          String
  description     String?
  favicon         String?
  status          String   @default("active") // active, archived, deleted
  isFavorite      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Business inputs
  monthlyVisits   Int      @default(0)
  valuePerVisit   Float    @default(0)

  // WordPress integration
  wpSiteUrl       String?
  wpUser          String?
  wpAppPassword   String?  // Encrypted

  // Project data
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audits          Audit[]
  workItems       WorkItem[]
  competitors     Competitor[]
  oauthCredentials OAuthCredential[]
  googleSearchConsole GoogleSearchConsoleMetric[]
  googleAnalytics4 GoogleAnalytics4Metric[]
  deployments     Deployment[]
  events          Event[]
  recommendations Recommendation[]

  // Decision Engine
  pageClassifications PageClassification[]
  pageSignals         PageSignals[]
  businessValueScores BusinessValueScore[]
  seoOpportunityScores SEOOpportunityScore[]
  pagePriorities      PagePriority[]
  recommendationDecisions RecommendationDecision[]
  dailyMissions       DailyMission[]

  @@unique([organizationId, domain])
  @@index([organizationId])
  @@index([status])
  @@index([isFavorite])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT & CRAWL DATA (Organization-scoped)
// ─────────────────────────────────────────────────────────────────────────────

model Audit {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  status          String   @default("pending") // pending, running, completed, failed
  startedAt       DateTime @default(now())
  endedAt         DateTime?

  // Crawl metadata
  pageCount       Int      @default(0)
  issueCount      Int      @default(0)
  criticalCount   Int      @default(0)
  warningCount    Int      @default(0)
  infoCount       Int      @default(0)

  // Scores
  siteScore       Int      @default(0)
  technicalScore  Int      @default(0)
  contentScore    Int      @default(0)
  schemaScore     Int      @default(0)
  aiScore         Int      @default(0)

  // Metrics
  schemaCoverage  Int      @default(0)
  orphanCount     Int      @default(0)
  avgInbound      Int      @default(0)

  // Summary
  summary         String?  // JSON

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages           Page[]
  issues          Issue[]
  events          Event[]

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([startedAt])
}

model Page {
  id              String   @id @default(cuid())
  auditId         String
  url             String
  status          Int      @default(0)

  // Content
  title           String?
  metaDescription String?
  h1              String?
  h1Count         Int      @default(0)
  contentLength   Int      @default(0)

  // Technical
  canonical       String?
  hasNoindex      Boolean  @default(false)
  hasMixedContent Boolean  @default(false)
  pageSpeedScore  Int?

  // Linking
  internalLinks   Int      @default(0)
  internalTargets Int      @default(0)
  inboundCount    Int      @default(0)

  // Schema & AI
  schemaTypes     String?  // JSON array
  aiScore         Int      @default(0)
  technicalScore  Int      @default(0)
  contentScore    Int      @default(0)
  schemaScore     Int      @default(0)

  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  issues          Issue[]

  @@unique([auditId, url])
  @@index([auditId])
  @@index([status])
}

model Issue {
  id              String   @id @default(cuid())
  auditId         String
  pageId          String
  type            String   // duplicate_title, missing_meta, etc
  severity        String   @default("info") // critical, warning, info
  title           String
  description     String?
  affectedPages   String?  // JSON array

  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([pageId])
  @@index([severity])
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATIONS & CREDENTIALS (Organization-scoped, Encrypted)
// ─────────────────────────────────────────────────────────────────────────────

model OAuthCredential {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String?
  provider        String   // google, microsoft, etc
  accessToken     String   // ENCRYPTED
  refreshToken    String?  // ENCRYPTED
  expiresAt       DateTime?
  scope           String?
  gscPropertyUrl  String?  // Encrypted
  ga4PropertyId   String?  // Encrypted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUsedAt      DateTime?

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider, projectId])
  @@index([organizationId])
  @@index([lastUsedAt])
}

model GoogleSearchConsoleMetric {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  url             String
  clicks          Int      @default(0)
  impressions     Int      @default(0)
  ctr             Float    @default(0)
  position        Float    @default(0)
  topQueries      String?  // JSON
  devices         String?  // JSON
  countries       String?  // JSON
  dataDate        DateTime?
  syncedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId, url])
  @@index([organizationId])
  @@index([projectId])
  @@index([url])
}

model GoogleAnalytics4Metric {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  url             String
  users           Int      @default(0)
  sessions        Int      @default(0)
  engagementRate  Float    @default(0)
  bounceRate      Float    @default(0)
  avgSessionDuration Float @default(0)
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  revenue         Float    @default(0)
  dataDate        DateTime?
  syncedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId, url])
  @@index([organizationId])
  @@index([projectId])
  @@index([url])
}

// ─────────────────────────────────────────────────────────────────────────────
// RECOMMENDATIONS & WORK ITEMS (Organization-scoped)
// ─────────────────────────────────────────────────────────────────────────────

model Recommendation {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  auditId         String?
  category        String
  title           String
  description     String?
  severity        String   @default("info")
  affectedPages   Int      @default(0)
  trafficGain     Int      @default(0)
  revenueGain     Float    @default(0)
  difficulty      String   @default("medium")
  estimatedMins   Int      @default(30)
  confidence      Int      @default(80)
  dismissed       Boolean  @default(false)
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([severity])
}

model WorkItem {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  auditId         String?
  url             String
  type            String   // title, meta, schema, technical, conversion, etc
  status          String   @default("detected") // 8-step workflow
  title           String
  description     String?
  why             String?
  estimatedTraffic Int    @default(0)
  estimatedRevenue Float  @default(0)
  priority        String   @default("medium")
  confidence      Int      @default(0)
  generatedFix    String?  // JSON encrypted
  fixPreview      String?
  approvedAt      DateTime?
  approvedBy      String?
  deployedAt      DateTime?
  deploymentId    String?
  deploymentStatus String?
  verifiedAt      DateTime?
  beforeMetrics   String?  // JSON
  afterMetrics    String?  // JSON
  verificationStatus String? // improved, no_change, regressed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPETITORS (Organization-scoped)
// ─────────────────────────────────────────────────────────────────────────────

model Competitor {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  domain          String
  displayName     String
  industry        String?
  notes           String?
  monitoringStatus String @default("active")
  crawlFrequency  Int      @default(7)
  lastCrawl       DateTime?
  lastComparison  DateTime?
  dateAdded       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots       CompetitorSnapshot[]
  changes         CompetitorChange[]
  opportunities   CompetitorOpportunity[]

  @@unique([projectId, domain])
  @@index([organizationId])
  @@index([projectId])
}

model CompetitorSnapshot {
  id              String   @id @default(cuid())
  organizationId  String
  competitorId    String
  pageCount       Int      @default(0)
  issueCount      Int      @default(0)
  technicalScore  Int      @default(0)
  contentScore    Int      @default(0)
  schemaScore     Int      @default(0)
  pages           String?  // JSON
  crawledAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([competitorId])
  @@index([crawledAt])
}

model CompetitorChange {
  id              String   @id @default(cuid())
  organizationId  String
  competitorId    String
  type            String   // newPages, removedPages, titleChanges, etc
  severity        String   @default("medium")
  description     String
  count           Int      @default(1)
  affectedPages   String?  // JSON
  impact          String?  // competitive_threat, opportunity, neutral
  impactReason    String?
  detectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([competitorId])
  @@index([detectedAt])
  @@index([type])
}

model CompetitorOpportunity {
  id              String   @id @default(cuid())
  organizationId  String
  competitorId    String
  changeType      String
  title           String
  description     String
  competitive_threat Boolean @default(false)
  opportunity     Boolean  @default(false)
  recommendedAction String?
  actionType      String?
  estimatedTraffic Int?
  estimatedDifficulty String?
  estimatedTime   Int?
  dismissed       Boolean  @default(false)
  implementedAt   DateTime?
  detectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([competitorId])
  @@index([detectedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEPLOYMENTS & HISTORY
// ─────────────────────────────────────────────────────────────────────────────

model Deployment {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  type            String   @default("deploy")
  status          String   @default("pending")
  targetUrl       String?
  changes         String?  // JSON
  error           String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENTS & AUDIT LOGGING
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String?
  auditId         String?
  type            String   // audit, deploy, forge_chat, recommendation_generated, etc
  action          String?
  metadata        String?  // JSON for extra context
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  audit           Audit?        @relation(fields: [auditId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  action          String   // user.login, project.created, credentials.changed, etc
  resource        String   // user, project, organization, credential
  resourceId      String
  changes         String?  // JSON of what changed
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGACY (Keep for now, will be removed)
// ─────────────────────────────────────────────────────────────────────────────

model ForgeMemory {
  id              String   @id @default(cuid())
  projectId       String   @unique
  messages        String   // JSON
  patterns        String?  // JSON
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}

model Recommendation_Legacy {
  id              String   @id @default(cuid())
  projectId       String
  auditId         String?
  category        String
  title           String
  description     String?
  severity        String   @default("info")
  affectedPages   Int      @default(0)
  trafficGain     Int      @default(0)
  revenueGain     Float    @default(0)
  difficulty      String   @default("medium")
  estimatedMins   Int      @default(30)
  confidence      Int      @default(80)
  dismissed       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([auditId])
  @@index([severity])
}

// ─────────────────────────────────────────────────────────────────────────────
// DECISION ENGINE
// ─────────────────────────────────────────────────────────────────────────────

model PageClassification {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  pageUrl          String

  // Classification results
  classifications  Json     // [{type: "ServicePage", confidence: 0.96, signals: [...]}]
  primaryClassification String
  confidenceScore  Float    // 0-1
  
  // Classification signals
  urlPattern       String?
  hasSchema        String[]
  hasForm          Boolean  @default(false)
  ctaButtons       String[]
  navigationLevel  String?  // "main", "secondary", "footer"
  internalLinkCount Int     @default(0)
  
  // Manual override
  manualClassification String?
  
  classifiedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  organization     Organization @relation("PageClassifications", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signals          PageSignals?

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([primaryClassification])
}

model PageSignals {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  pageUrl          String

  // GA4 Signals
  ga4_monthlyVisitors Int   @default(0)
  ga4_monthlyConversions Int @default(0)
  ga4_conversionRate Float  @default(0)
  ga4_conversionValue Float @default(0)
  ga4_30dayTrend   Float    @default(0)
  ga4_lastUpdated  DateTime?

  // GSC Signals
  gsc_monthlyImpressions Int   @default(0)
  gsc_monthlyClicks Int         @default(0)
  gsc_ctr          Float        @default(0)
  gsc_avgPosition  Float        @default(0)
  gsc_industryAvgCtr Float      @default(0)
  gsc_30dayTrend   Float        @default(0)
  gsc_lastUpdated  DateTime?

  // Crawl Signals
  crawl_status     Int           @default(0)
  crawl_title      String?
  crawl_metaDescription String?
  crawl_h1         String?
  crawl_contentLength Int        @default(0)
  crawl_internalLinks Int        @default(0)
  crawl_inboundCount Int         @default(0)
  crawl_hasCanonical Boolean     @default(false)
  crawl_hasNoindex Boolean       @default(false)
  crawl_schemaTypes String[]
  crawl_coreWebVitals Json?
  crawl_mobileUsable Boolean     @default(true)
  crawl_lastCrawled DateTime?

  // Technical Signals
  technical_issueCount Int @default(0)
  technical_criticalIssues Int @default(0)
  technical_score Int @default(0)

  // Content Signals
  content_score    Int    @default(0)
  content_daysOld  Int    @default(0)
  content_lastUpdated DateTime?

  // Schema Signals
  schema_score     Int    @default(0)
  schema_hasLocalBusiness Boolean @default(false)
  schema_hasService Boolean @default(false)
  schema_hasFAQ    Boolean @default(false)
  schema_completeness Float @default(0)

  // Business Signals
  business_strategicImportance Int?
  business_manualPriority String?  // "MISSION_CRITICAL", "HIGH", "NORMAL", "IGNORE"
  business_revenuePotential Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("PageSignals", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  classification   PageClassification @relation(fields: [projectId, pageUrl], references: [projectId, pageUrl], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([ga4_30dayTrend])
  @@index([gsc_avgPosition])
}

model BusinessValueScore {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  pageUrl          String

  // Component scores (0-100)
  revenueScore     Int
  conversionScore  Int
  strategicScore   Int
  navigationScore  Int
  authorityScore   Int
  trendScore       Int
  manualPriorityScore Int

  // Weights used
  weightsUsed      Json?    // {"revenue": 0.40, ...}

  // Final score
  totalBusinessValue Int    // 0-100
  explanation      String?

  calculatedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("BusinessValueScores", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([totalBusinessValue])
}

model SEOOpportunityScore {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  pageUrl          String

  // Component scores (0-100)
  rankingGapScore  Int
  ctrGapScore      Int
  impressionScore  Int
  schemaGapsScore  Int
  internalLinkingScore Int
  indexabilityScore Int
  coreWebVitalsScore Int
  contentFreshnessScore Int
  backlinksScore   Int
  duplicateContentScore Int

  // Weights used
  weightsUsed      Json?

  // Final score
  totalSeoOpportunity Int   // 0-100
  identifiedOpportunities Json?
  explanation      String?

  calculatedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("SEOOpportunityScores", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([totalSeoOpportunity])
}

model PagePriority {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  auditId          String
  pageUrl          String

  // Component scores
  businessValueScore    Int      // 0-100
  seoOpportunityScore   Int      // 0-100

  // Weighted priority
  priorityScore    Int      // 0-100
  businessWeight Float @default(0.60)
  seoWeight Float @default(0.40)

  // Ranking
  priorityRank     Int      // position among all pages
  percentile       Float    // 0-100

  // Explainability
  explainability   Json?     // {businessValueDriver, seoOpportunityDriver, combinedRationale, whyThisPage, whyNow, keyFactors, risks}
  summary          String

  calculatedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("PagePriorities", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([auditId, pageUrl])
  @@index([organizationId])
  @@index([projectId])
  @@index([auditId])
  @@index([priorityScore])
  @@index([priorityRank])
}

model RecommendationDecision {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  pageUrl          String
  recommendationType String

  // Scoring
  businessValue    Int
  seoOpportunity   Int
  expectedBusinessReturn Json
  difficulty       Int      // 1-10
  riskLevel        String   // "Very Low", "Low", "Medium", "High", "Very High"
  riskExplanation  String?
  estimatedTime    Int      // minutes
  timeToWin        String   // "Immediate", "Short Term", etc
  dependencies     String[]

  // Explainability
  whyThis          String
  whyNow           String
  whyThisPage      String
  whyThisPriority  String
  confidence       Float    // 0-1
  dataSupporting   Json

  // Prediction & verification
  prediction       Json?
  deployment       DateTime?
  actualResult     Json?
  variance         Float?
  verifiedAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("RecommendationDecisions", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl, recommendationType])
  @@index([organizationId])
  @@index([projectId])
}

model DailyMission {
  id               String   @id @default(cuid())
  organizationId   String
  projectId        String
  date             DateTime @default(now())

  // Selected recommendation
  pageUrl          String
  recommendationType String
  
  // Context
  reasoning        String
  expectedReturn   Json
  estimatedTime    Int
  difficulty       Int

  // Status
  status           String   @default("active")  // "active", "completed", "skipped"
  completedAt      DateTime?
  actualTime       Int?
  actualResult     Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation("DailyMissions", fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
}

model BusinessContext {
  id               String   @id @default(cuid())
  organizationId   String   @unique

  // Business mode
  businessMode     String   @default("general")

  // Weighting preferences
  businessValueWeights Json?
  seoOpportunityWeights Json?
  priorityWeights  Json?

  // Business priorities
  highestValueServices String[]
  highestValueLocations String[]
  primaryConversionGoal String?
  secondaryConversionGoal String?

  // Constraints
  maxDeploymentsPerDay Int @default(5)
  requiresManualApproval Boolean @default(true)
  autoApproveRiskLevel String?

  updatedAt        DateTime @updatedAt

  organization     Organization @relation("BusinessContext", fields: [organizationId], references: [id], onDelete: Cascade)
}
