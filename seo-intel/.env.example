# ── SERP provider (required for live SERP data) ────────────────────────────
# SerpAPI key from https://serpapi.com/manage-api-key
SERP_API_KEY=

# ── AI recommendation engine (at least one recommended) ────────────────────
# Anthropic Claude API key (preferred) — https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI API key (fallback provider) — https://platform.openai.com
OPENAI_API_KEY=

# ── Google PageSpeed Insights (optional — raises rate limits) ──────────────
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# ── Backlink data (optional) — DataForSEO https://dataforseo.com ────────────
# Format: "login:password" for DataForSEO Basic auth
DATAFORSEO_API_KEY=

# ── Database (optional) ─────────────────────────────────────────────────────
# PostgreSQL connection string, e.g. postgres://user:pass@host:5432/seo_intel
# If unset, reports are stored in a local JSON file store under .data/
DATABASE_URL=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to encrypt API keys saved from the Settings page (32+ chars).
# Generate with: openssl rand -hex 32
APP_SECRET=
# Max competitor pages to run PageSpeed Insights against per report (default 3).
PSI_COMPETITOR_LIMIT=3
