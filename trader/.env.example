# ----------------------------------------------------------------------------
# TMAC Trader — environment configuration
# Copy to .env.local (Next.js) and fill in. NEVER commit real secrets.
# Everything here is OPTIONAL: with no config the app runs in paper mode with a
# synthetic market-data feed and an in-memory/JSON store.
# ----------------------------------------------------------------------------

# Required only if you want to save broker API keys from the in-app Settings UI.
# Used to AES-256-GCM encrypt stored secrets. Generate: openssl rand -hex 32
# If unset, the Settings UI cannot store keys — provide credentials via env vars.
APP_SECRET=

# --- Robinhood Crypto Trading API (official) -------------------------------
# Docs: https://docs.robinhood.com/crypto/trading/
# Generate an Ed25519 key pair, register the PUBLIC key in the Robinhood API
# Credentials portal, and put the API key + base64 PRIVATE-key seed here.
# Used for LIVE crypto trading only. Leave blank to stay in paper mode.
RH_CRYPTO_API_KEY=
RH_CRYPTO_PRIVATE_KEY=

# --- Equities / Options ----------------------------------------------------
# No public self-serve REST API exists for programmatic Robinhood equities/
# options. This requires approved access (e.g. Robinhood Agentic Trading) or
# another approved brokerage API. Add credentials here once you wire the
# adapter in lib/brokers/robinhood-equities-options.ts.
# RH_EQUITIES_API_KEY=

# --- Optional production database ------------------------------------------
# By default the app uses an in-memory/JSON store (./.data/state.json), which is
# perfect for a single-user local/always-on deployment. For multi-instance or
# serverless deployments, provision Postgres and run `prisma migrate` against
# the schema in prisma/schema.prisma, then implement a PostgresStore.
# DATABASE_URL=postgresql://user:pass@localhost:5432/tmac_trader
